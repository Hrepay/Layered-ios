rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOf(familyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isAdminOf(familyId) {
      return isMemberOf(familyId)
        && get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // users: 본인 문서는 본인만 쓰기. 읽기는 인증된 사용자에게 허용(가족 가입 플로우에서 상대 정보 조회)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isMe(userId);
    }

    // families: 가족 멤버 기반 권한
    match /families/{familyId} {
      allow read: if isSignedIn();            // 초대 코드 검색 위해 인증된 사용자면 허용
      allow create: if isSignedIn();
      allow update: if isMemberOf(familyId);
      allow delete: if isAdminOf(familyId);

      // 멤버 서브컬렉션
      match /members/{memberId} {
        allow read: if isMemberOf(familyId) || isMe(memberId);
        allow create: if isMe(memberId);       // 가입 시 본인만 자기 자신을 추가
        allow update: if isMe(memberId)
                      || isAdminOf(familyId)
                      // 일반 구성원도 플래너 순서 변경은 허용 (rotationOrder 필드만 바뀔 때)
                      || (isMemberOf(familyId)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rotationOrder']));
        allow delete: if isMe(memberId) || isAdminOf(familyId);
      }

      // 모임 서브컬렉션
      match /meetings/{meetingId} {
        allow read: if isMemberOf(familyId);
        allow create: if isMemberOf(familyId);
        allow update: if isMemberOf(familyId);
        allow delete: if isMemberOf(familyId)
          && (resource.data.plannerId == request.auth.uid || isAdminOf(familyId));

        // 기록: 본인 기록만 수정, 삭제는 본인 또는 가정 관리자(가정/모임 삭제 cascade용)
        match /records/{recordId} {
          allow read: if isMemberOf(familyId);
          allow create: if isMemberOf(familyId)
            && request.resource.data.memberId == request.auth.uid;
          allow update: if isMemberOf(familyId)
            && resource.data.memberId == request.auth.uid;
          allow delete: if isMemberOf(familyId)
            && (resource.data.memberId == request.auth.uid || isAdminOf(familyId));
        }

        // 투표: 가족 멤버는 조회/투표 가능
        match /polls/{pollId} {
          allow read, write: if isMemberOf(familyId);
        }

        // 모임 의견: 멤버 누구나 읽기/작성, 수정·삭제는 본인만
        match /comments/{commentId} {
          allow read: if isMemberOf(familyId);
          allow create: if isMemberOf(familyId)
            && request.resource.data.userId == request.auth.uid;
          allow update: if isMemberOf(familyId)
            && resource.data.userId == request.auth.uid
            // 작성자 정보는 변경 불가
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.userName == resource.data.userName
            && request.resource.data.createdAt == resource.data.createdAt;
          allow delete: if isMemberOf(familyId)
            && resource.data.userId == request.auth.uid;
        }

        // 콕 찌르기: 멤버가 생성하되 보낸이는 본인이어야 함(스푸핑 방지).
        // 읽기·삭제는 모임 삭제 cascade 위해 멤버 허용, 생성된 기록은 수정 불가.
        match /nudges/{nudgeId} {
          allow read: if isMemberOf(familyId);
          allow create: if isMemberOf(familyId)
            && request.resource.data.fromUserId == request.auth.uid;
          allow update: if false;
          allow delete: if isMemberOf(familyId);
        }
      }

      // 한 겹(노트): 모임과 독립된 가벼운 메모. 작성자 본인만 수정, 삭제는 본인 또는 관리자.
      match /notes/{noteId} {
        allow read: if isMemberOf(familyId);
        allow create: if isMemberOf(familyId)
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isMemberOf(familyId)
          && resource.data.authorId == request.auth.uid
          // 작성자 정보는 변경 불가
          && request.resource.data.authorId == resource.data.authorId;
        allow delete: if isMemberOf(familyId)
          && (resource.data.authorId == request.auth.uid || isAdminOf(familyId));
      }
    }

    // 위 경로 외 전부 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
